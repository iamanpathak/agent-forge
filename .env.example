# -----------------------------------------------------------------------------
# AgentForge Environment Variables Template
# -----------------------------------------------------------------------------
# INSTRUCTIONS: Rename this file to .env or .env.local and fill in your keys.
# DO NOT commit your actual .env file to version control!
# -----------------------------------------------------------------------------

# --- DATABASE SETUP ---
# Connection string for your PostgreSQL database (Local Docker or Cloud like Neon/Supabase)
DATABASE_URL="postgresql://YOUR_USER:YOUR_PASSWORD@localhost:5432/agentforge_db?schema=public"

# --- AI & THIRD-PARTY APIS ---
# Get your API key from https://console.groq.com
GROQ_API_KEY="gsk_your_groq_api_key_here"

# Get your API key from https://tavily.com (For Live Web Search Node)
TAVILY_API_KEY="tvly_your_tavily_api_key_here"

# Get your API key from https://resend.com (For Email Node)
RESEND_API_KEY="re_your_resend_api_key_here"

# --- CLERK AUTHENTICATION ---
# Get these from your Clerk Dashboard: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_your_publishable_key_here"
CLERK_SECRET_KEY="sk_test_your_secret_key_here"

# Standard Clerk Routing (Usually no need to change these)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/